{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loquera",
  "version": "0.1.0",
  "identifier": "dev.loquera.mvp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Loquera",
        "width": 1180,
        "height": 760,
        "minWidth": 840,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
